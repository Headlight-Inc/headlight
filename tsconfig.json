{
  "compilerOptions": {
    "target": "ES2022",
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "module": "ESNext",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "skipLibCheck": true,
    "types": [
      "node"
    ],
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "moduleDetection": "force",
    "allowJs": true,
    "jsx": "react-jsx",
    "paths": {
      "@/*": [
        "./*"
      ],
      "@headlight/types": [
        "./packages/types/src"
      ],
      "@headlight/types/*": [
        "./packages/types/src/*"
      ],
      "@headlight/metrics": [
        "./packages/metrics/src"
      ],
      "@headlight/metrics/*": [
        "./packages/metrics/src/*"
      ],
      "@headlight/modes": [
        "./packages/modes/src"
      ],
      "@headlight/modes/*": [
        "./packages/modes/src/*"
      ],
      "@headlight/actions": [
        "./packages/actions/src"
      ],
      "@headlight/actions/*": [
        "./packages/actions/src/*"
      ],
      "@headlight/fingerprint": [
        "./packages/fingerprint/src"
      ],
      "@headlight/fingerprint/*": [
        "./packages/fingerprint/src/*"
      ],
      "@headlight/compute": [
        "./packages/compute/src"
      ],
      "@headlight/compute/*": [
        "./packages/compute/src/*"
      ]
    },
    "allowImportingTsExtensions": true,
    "noEmit": true
  }
}